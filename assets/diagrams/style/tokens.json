{
  "$schema": "https://schemas.contextengineering.dev/diagram-tokens/v1.json",
  "description": "Shared design tokens for every diagram in the Context Engineering series. Light + dark variants. Colour-blind safe (Okabe-Ito derived).",
  "palette": {
    "light": {
      "bg":         "#FAFAF7",
      "surface":    "#FFFFFF",
      "ink":        "#1A1A1A",
      "ink_muted":  "#5C5C5C",
      "ink_subtle": "#9A9A9A",
      "border":     "#D9D9D4",
      "primary":    "#5B7FBF",
      "accent":     "#D98E5F",
      "success":    "#5C9E78",
      "warn":       "#B8895A",
      "alert":      "#C66B5E",
      "neutral_1":  "#EAEAE4",
      "neutral_2":  "#CFCFC8",
      "neutral_3":  "#8E8E88"
    },
    "dark": {
      "bg":         "#0E0F12",
      "surface":    "#16181C",
      "ink":        "#F2F2EE",
      "ink_muted":  "#B4B4AE",
      "ink_subtle": "#6E6E68",
      "border":     "#2A2D33",
      "primary":    "#8BA8E0",
      "accent":     "#E8B088",
      "success":    "#7FBF9B",
      "warn":       "#D4B58A",
      "alert":      "#D88880",
      "neutral_1":  "#1F2229",
      "neutral_2":  "#2C3038",
      "neutral_3":  "#6E6E68"
    }
  },
  "typography": {
    "label_family":   "Inter, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif",
    "mono_family":    "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace",
    "title_size_px":  20,
    "label_size_px":  14,
    "small_size_px":  12,
    "code_size_px":   13,
    "title_weight":   600,
    "label_weight":   500
  },
  "stroke": {
    "primary_px":   1.5,
    "secondary_px": 1.0,
    "hairline_px":  0.75,
    "dasharray":    "4 3"
  },
  "geometry": {
    "max_width_px":   960,
    "padding_px":     32,
    "corner_radius":  10,
    "icon_size_px":   24
  },
  "scale": {
    "retina_multiplier": 2
  }
}
